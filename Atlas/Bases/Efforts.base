views:
  - type: table
    name: All
    filters:
      and:
        - file.inFolder("Efforts")
        - status != "sleeping"
        - status != "simmering⌛️"
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - rank
      - status
    sort:
      - property: status
        direction: ASC
      - property: rank
        direction: DESC
    columnSize:
      file.name: 276
      note.rank: 118
      note.status: 278
